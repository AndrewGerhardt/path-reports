<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Camp Geiger Summer Offering Reporting</title>
  <link rel="stylesheet" href="css/styles.css">
</head>

<body>
  <div class="app">
    <header>
      <div>
        <h1>Camp Geiger Summer Offering Reporting</h1>
        <p id="generatedAt">Loading report data...</p>
      </div>

      <div class="headerButtons">
        <button onclick="resetDefaultSort()">Reset Sort</button>
        <button onclick="downloadCsv()">Export Current View CSV</button>
      </div>
    </header>

    <section class="filters">
      <label>
        View
        <select id="viewSelect" onchange="renderCurrentView()">
          <option value="summer">Whole Summer</option>
          <option value="weekly">By Week</option>
          <option value="normalized">Weekly Average</option>
          <option value="completion">Completion</option>
        </select>
      </label>

      <label>
        Year
        <select id="yearFilter" onchange="renderCurrentView()"></select>
      </label>

      <label id="sessionFilterLabel">
        Session
        <select id="sessionFilter" onchange="renderCurrentView()"></select>
      </label>

      <label>
        Area
        <select id="areaFilter" onchange="renderCurrentView()"></select>
      </label>

      <label>
        Class Time
        <select id="timeFilter" onchange="renderCurrentView()"></select>
      </label>

      <label>
        Search
        <input id="searchBox" type="text" placeholder="Badge name..." oninput="renderCurrentView()">
      </label>
    </section>

    <section id="summaryCards" class="cards"></section>

    <main>
      <table>
        <thead id="tableHead"></thead>
        <tbody id="tableBody"></tbody>
      </table>
    </main>
  </div>

  <script src="js/app.js"></script>
</body>
</html>
